# =============================================================================
# TODAS as variáveis do Dondoquinha — importar na Vercel (arquivo: vercel.env)
# =============================================================================
#
# BANCO DE DADOS (Supabase) — só estas 2 conectam ao banco:
#   NEXT_PUBLIC_SUPABASE_URL      → URL do projeto
#   NEXT_PUBLIC_SUPABASE_ANON_KEY → chave pública (Publishable / anon)
#
# Não existe DATABASE_URL nem senha do Postgres no site.
# Tudo passa pela API do Supabase com essas 2 variáveis.
#
# LOGIN DO SISTEMA:
#   AUTH_USER, AUTH_PASSWORD, AUTH_SECRET
#
# LOGIN COM DIGITAL NO CELULAR:
#   NEXT_PUBLIC_WEBAUTHN_RP_ID, NEXT_PUBLIC_APP_URL
#
# OPCIONAL:
#   NEXT_PUBLIC_APK_URL → link para baixar APK Android
#
# COMO IMPORTAR:
# 1. Vercel → dondoquinha → Settings → Environment Variables
# 2. Import .env → selecione vercel.env
# 3. Marque Production, Preview e Development
# 4. Save → Redeploy
# =============================================================================

# --- BANCO DE DADOS (obrigatório) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLE_SUA_CHAVE_PUBLISHABLE_AQUI

# --- LOGIN (obrigatório) ---
AUTH_USER=dondoquinha
AUTH_PASSWORD=sua-senha-de-login
AUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio

# --- DIGITAL NO CELULAR (obrigatório em produção) ---
NEXT_PUBLIC_WEBAUTHN_RP_ID=dondoquinha-one.vercel.app
NEXT_PUBLIC_APP_URL=https://dondoquinha-one.vercel.app

# --- OPCIONAL ---
# NEXT_PUBLIC_APK_URL=https://dondoquinha-one.vercel.app/dondoquinha.apk
