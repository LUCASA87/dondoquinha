# =============================================================================
# Variáveis de ambiente — Dondoquinha (importar na Vercel)
# =============================================================================
#
# COMO USAR:
# 1. Copie este arquivo e renomeie para: vercel.env
# 2. Preencha URL e chave do Supabase (painel Supabase → Settings → API)
# 3. Na Vercel: projeto dondoquinha → Settings → Environment Variables
# 4. Clique em "Import .env" e selecione o arquivo vercel.env
# 5. Marque os ambientes: Production, Preview e Development
# 6. Salve e faça Redeploy em Deployments → ⋯ → Redeploy
#
# =============================================================================

# --- Supabase (obrigatório) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLE_SUA_CHAVE_ANON_AQUI

# --- Login do sistema ---
AUTH_USER=dondoquinha
AUTH_PASSWORD=203189
AUTH_SECRET=dondoquinha-gestao-2026-troque-por-um-segredo-longo

# --- PWA / celular (opcional) ---
# URL pública do APK Android, se você gerar um pacote para download direto
# NEXT_PUBLIC_APK_URL=https://seu-dominio.com/dondoquinha.apk
# Domínio para digital/Face ID (use o domínio de produção sem https://)
# NEXT_PUBLIC_WEBAUTHN_RP_ID=dondoquinha-one.vercel.app
# NEXT_PUBLIC_APP_URL=https://dondoquinha-one.vercel.app
